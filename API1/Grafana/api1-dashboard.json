    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx Error % — Stable vs Canary",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_server_request_duration_seconds_count{service_version=\"v1-stable\", http_response_status_code=~\"5..\"}[1m])) / sum(rate(http_server_request_duration_seconds_count{service_version=\"v1-stable\"}[1m]))",
          "legendFormat": "5xx% stable",
          "refId": "A"
        },
        {
          "expr": "100 * sum(rate(http_server_request_duration_seconds_count{service_version=\"v1-canary\", http_response_status_code=~\"5..\"}[1m])) / sum(rate(http_server_request_duration_seconds_count{service_version=\"v1-canary\"}[1m]))",
          "legendFormat": "5xx% canary",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx% stable" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "5xx% canary" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
