      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_version=\"v1-stable\", http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx stable",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_version=\"v1-canary\", http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx canary",
