{
  "title": "API1 — Canary vs Stable",
  "uid": "api1-canary-stable-v2",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 100,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "options": {
        "mode": "markdown",
        "content": "## 📊 Request Volume"
      }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate — Stable (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(aspnetcore_routing_match_attempts_total{service_version=\"v1-stable\", aspnetcore_routing_match_status=\"success\"}[1m]))",
          "legendFormat": "stable",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate — Canary (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(aspnetcore_routing_match_attempts_total{service_version=\"v1-canary\", aspnetcore_routing_match_status=\"success\"}[1m]))",
          "legendFormat": "canary",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 }
    },
    {
      "id": 101,
      "type": "text",
      "title": "",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "options": {
        "mode": "markdown",
        "content": "## ⏱️ Latency — P95 & P90"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "P95 Latency — Stable vs Canary",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service_version=\"v1-stable\"}[2m])) by (le))",
          "legendFormat": "p95 stable",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service_version=\"v1-canary\"}[2m])) by (le))",
          "legendFormat": "p95 canary",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" },
        "exemplars": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p95 stable" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95 canary" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          }
        ]
      },
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "P90 Latency — Stable vs Canary",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
